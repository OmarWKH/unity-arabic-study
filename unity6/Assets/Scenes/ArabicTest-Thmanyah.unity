--- !u!114 &1893514631
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1893514629}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "=== Plain words (no harakat) ===\n\u0627\u0644\u0633\u0644\u0627\u0645
    \u0639\u0644\u064A\u0643\u0645 \u0648\u0631\u062D\u0645\u0629 \u0627\u0644\u0644\u0647
    \u0648\u0628\u0631\u0643\u0627\u062A\u0647\n\u0628\u0633\u0645 \u0627\u0644\u0644\u0647
    \u0627\u0644\u0631\u062D\u0645\u0646 \u0627\u0644\u0631\u062D\u064A\u0645\n\u0645\u0631\u062D\u0628\u0627
    \u0628\u0643\u0645 \u0641\u064A \u064A\u0648\u0646\u064A\u062A\u064A\n\n=== Full
    harakat (Fatha, Kasra, Damma, Sukun) ===\n\u0628\u0650\u0633\u0652\u0645\u0650
    \u0627\u0644\u0644\u064E\u0651\u0647\u0650 \u0627\u0644\u0631\u064E\u0651\u062D\u0652\u0645\u064E\u0670\u0646\u0650
    \u0627\u0644\u0631\u064E\u0651\u062D\u0650\u064A\u0645\u0650\n\u0627\u0644\u0652\u062D\u064E\u0645\u0652\u062F\u064F
    \u0644\u0650\u0644\u064E\u0651\u0647\u0650 \u0631\u064E\u0628\u0650\u0651 \u0627\u0644\u0652\u0639\u064E\u0627\u0644\u064E\u0645\u0650\u064A\u0646\u064E\n\u0645\u064E\u0627\u0644\u0650\u0643\u0650
    \u064A\u064E\u0648\u0652\u0645\u0650 \u0627\u0644\u062F\u0650\u0651\u064A\u0646\u0650\n\n===
    Mark-to-mark stress test (shadda + vowel) ===\n\u0645\u064F\u062D\u064E\u0645\u064E\u0651\u062F\u064C
    \u2014 \u0627\u0644\u0644\u064E\u0651\u0640\u0647\u064F \u2014 \u0627\u0644\u0631\u064E\u0651\u062D\u0652\u0645\u064E\u0640\u0670\u0646\u064F
    \u2014 \u0627\u0644\u0631\u064E\u0651\u062D\u0650\u064A\u0645\u064F\n\u062B\u064F\u0645\u064E\u0651
    \u2014 \u0623\u064E\u0646\u064E\u0651 \u2014 \u0625\u0650\u0646\u064E\u0651 \u2014
    \u0643\u064E\u0623\u064E\u0646\u064E\u0651\n\n=== Tanwin (double diacritics)
    ===\n\u0643\u0650\u062A\u064E\u0627\u0628\u064C \u2014 \u0642\u064E\u0644\u064E\u0645\u064D
    \u2014 \u0628\u064E\u064A\u0652\u062A\u064B\u0627\n\n=== Mixed RTL / LTR / digits
    ===\n\u0627\u0644\u0625\u0635\u062F\u0627\u0631 3.2.0-pre.15 \u064A\u062F\u0639\u0645
    OpenType Layout\n\u0627\u0644\u0633\u0646\u0629 2026 \u2014 Unity 6000.0.32f1\n\n===
    Long passage ===\n\u0648\u064E\u0646\u064F\u0646\u064E\u0632\u0650\u0651\u0644\u064F
    \u0645\u0650\u0646\u064E \u0627\u0644\u0652\u0642\u064F\u0631\u0652\u0622\u0646\u0650
    \u0645\u064E\u0627 \u0647\u064F\u0648\u064E \u0634\u0650\u0641\u064E\u0627\u0621\u064C
    \u0648\u064E\u0631\u064E\u062D\u0652\u0645\u064E\u0629\u064C \u0644\u0650\u0651\u0644\u0652\u0645\u064F\u0624\u0652\u0645\u0650\u0646\u0650\u064A\u0646\u064E\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 12d6b063b81043d47a9fdf436e464caf, type: 2}
  m_sharedMaterial: {fileID: 7371889561612680774, guid: 12d6b063b81043d47a9fdf436e464caf, type: 2}
